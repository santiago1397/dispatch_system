# agents_bots Environment Variables

# === Project ===
PROJECT_NAME=agents_bots
DEBUG=true
ENVIRONMENT=local

# === Logfire ===
# Get your token at https://logfire.pydantic.dev
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=agents_bots
LOGFIRE_ENVIRONMENT=development

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agents_bots

# === JWT Auth ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# === Prometheus ===
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_INCLUDE_IN_SCHEMA=false

# === AI Agent (langchain, openai) ===
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7

# === LangSmith (LangChain Observability) ===
# Get your API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agents_bots
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === CORS ===
# JSON list of allowed origins (default: localhost:3000, localhost:8080)
# Note: "*" is blocked in production - specify explicit origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# === OpenPhone (Quo API) ===
# Get your API key from OpenPhone workspace settings > API tab
OPENPHONE_API_KEY=
# Webhook secret (the "key" returned when creating a webhook via the API)
OPENPHONE_WEBHOOK_SECRET=
OPENPHONE_BASE_URL=https://api.openphone.com/v1

# === Browser Automation (Playwright) ===
# Set to true only after running: uv run playwright install chromium
BROWSER_ENABLED=false
BROWSER_HEADLESS=true
BROWSER_CHANNEL=chromium
BROWSER_USER_DATA_DIR=browser_data

# === Docker Production (Traefik) ===
# Domain for production deployment
DOMAIN=example.com

# Let's Encrypt email for SSL certificates
ACME_EMAIL=admin@example.com

# Traefik dashboard auth (generate with: htpasswd -nb admin password)
# TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...
