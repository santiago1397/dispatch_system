# Production env for dispatch_chicago — copy to dispatch_bot/.env.prod on the server
# (this file is the template; never commit the real one)

# --- Runtime ---
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=                       # generate: python -c "import secrets; print(secrets.token_urlsafe(64))"

# --- Postgres (native on host, reached from container via host.docker.internal) ---
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                # your existing native password
POSTGRES_DB=dispatch

# --- CORS (must list the public frontend origins) ---
# This is read by backend/app/main.py; a literal "*" is rejected in production.
CORS_ORIGINS=["https://santiagoproperties.uk","https://www.santiagoproperties.uk"]
CORS_ALLOW_CREDENTIALS=true

# --- OpenAI (required for LLM classification — see CLAUDE.md) ---
OPENAI_API_KEY=

# --- Optional telemetry ---
LOGFIRE_TOKEN=

# --- Docker host-side port bindings (override only if there's a conflict) ---
APP_PORT=8888
FRONTEND_PORT=3333

# --- Frontend public URLs (read at build time, baked into the JS bundle) ---
NEXT_PUBLIC_WS_URL=wss://api.santiagoproperties.uk
